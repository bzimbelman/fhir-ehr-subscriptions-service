  "description": "At-a-glance interface-engine pipeline health: inbound rate, transform/HAPI POST latency, end-to-end latency, DLQ size and transitions. Built from the v1.0 metric catalog.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "subscription-service-prometheus" },
      "description": "Total inbound messages ever observed (sum across all status transitions and dimensions).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showPercentChange": false,
        "textMode": "auto"
      },
      "pluginVersion": "11.4.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "subscription-service-prometheus" },
          "editorMode": "code",
          "expr": "sum(interface_engine_ingested_messages_total)",
          "legendFormat": "messages",
          "range": false,
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Inbound messages (total)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "subscription-service-prometheus" },
      "description": "Current count of rows in DEAD_LETTER. Operator action required when > 0.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showPercentChange": false,
        "textMode": "auto"
      },
      "pluginVersion": "11.4.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "subscription-service-prometheus" },
          "editorMode": "code",
          "expr": "interface_engine_dlq_current_size",
          "legendFormat": "DLQ size",
          "range": false,
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "DLQ current size",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "subscription-service-prometheus" },
      "description": "Inbound rate (messages/sec) sliced by terminal status. Watch for a divergence between RECEIVED and DELIVERED — that's the queue growing.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "msg/s",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 3,
      "options": {
        "legend": { "calcs": ["mean", "lastNotNull"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "11.4.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "subscription-service-prometheus" },
          "editorMode": "code",
          "expr": "sum by (status) (rate(interface_engine_ingested_messages_total[5m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "title": "Inbound rate by status",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "subscription-service-prometheus" },
      "description": "Matchbox $transform latency — p95 and p99 across all outcomes. The histogram_quantile sum-by-le pattern is required because Micrometer's histogram is per-bucket; collapsing the outcome label preserves the bucket boundaries.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "seconds",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 4,
      "options": {
        "legend": { "calcs": ["mean", "lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "11.4.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "subscription-service-prometheus" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(interface_engine_transform_duration_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "subscription-service-prometheus" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(interface_engine_transform_duration_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "B"
        }
      ],
      "title": "Matchbox transform latency (p95 / p99)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "subscription-service-prometheus" },
      "description": "HAPI Bundle transaction POST latency — p95 / p99 across outcomes. Same shape as the transform timer above.",
