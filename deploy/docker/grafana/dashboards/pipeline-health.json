        "legend": { "calcs": ["mean", "lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "11.4.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "subscription-service-prometheus" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(interface_engine_hapi_post_duration_seconds_bucket[5m])))",
          "legendFormat": "p95",
