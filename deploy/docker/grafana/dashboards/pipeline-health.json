        },
        {
          "datasource": { "type": "prometheus", "uid": "subscription-service-prometheus" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(interface_engine_received_to_delivered_seconds_bucket[5m])))",
          "legendFormat": "p99",
