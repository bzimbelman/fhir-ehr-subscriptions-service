{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "HAPI FHIR R5-backport Subscription delivery health: active subscriptions, success rate, latency, top failing channels. Metric source: hapi/auth/SubscriptionMetricsInterceptor.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "subscription-service-prometheus" },
      "description": "Number of currently active Subscription resources in HAPI's in-process registry. Reflects HAPI's source of truth, not a polled DB count.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showPercentChange": false,
        "textMode": "auto"
      },
      "pluginVersion": "11.4.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "subscription-service-prometheus" },
          "editorMode": "code",
          "expr": "hapi_subscription_active",
          "legendFormat": "active",
          "instant": true,
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Active subscriptions",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "subscription-service-prometheus" },
      "description": "Delivery success ratio over a 5-minute window. Anything below ~95% sustained warrants investigation; a drop to 0 typically means a customer endpoint is offline.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "ratio",
            "axisSoftMin": 0,
            "axisSoftMax": 1,
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.9 },
              { "color": "green", "value": 0.99 }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 0 },
      "id": 2,
      "options": {
        "legend": { "calcs": ["mean", "lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "11.4.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "subscription-service-prometheus" },
          "editorMode": "code",
          "expr": "sum(rate(hapi_subscription_delivery_total{outcome=\"success\"}[5m])) / clamp_min(sum(rate(hapi_subscription_delivery_total[5m])), 1e-9)",
          "legendFormat": "success ratio",
          "refId": "A"
        }
      ],
      "title": "Delivery success rate (5m)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "subscription-service-prometheus" },
      "description": "p95 delivery duration sliced by outcome. Failure timings can be misleading because they often time out — they're plotted so operators can spot pathological hung deliveries.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "seconds",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "options": {
        "legend": { "calcs": ["mean", "lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "11.4.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "subscription-service-prometheus" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le, outcome) (rate(hapi_subscription_delivery_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{outcome}}",
          "refId": "A"
        }
      ],
      "title": "Delivery duration p95 by outcome",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "subscription-service-prometheus" },
      "description": "Failure rate sliced by channel_type (REST_HOOK, MESSAGE, etc.). The interceptor labels each delivery with HAPI's channel-type enum — a noisy channel jumps out here.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.1 }
            ]
          },
          "unit": "ops"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Failures / sec" },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Failures / sec" }]
      },
      "pluginVersion": "11.4.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "subscription-service-prometheus" },
          "editorMode": "code",
          "expr": "topk(10, sum by (channel_type) (rate(hapi_subscription_delivery_total{outcome=\"failure\"}[5m])))",
          "format": "table",
          "instant": true,
          "legendFormat": "{{channel_type}}",
          "refId": "A"
        }
      ],
      "title": "Top failing channel types (5m)",
      "type": "table"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["subscription-service", "hapi", "subscription"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Subscription Delivery",
  "uid": "subscription-service-delivery",
  "version": 1,
  "weekStart": ""
}
