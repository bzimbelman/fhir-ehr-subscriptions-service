        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "JVM and system-level health for the two services. Uses default Spring Boot / Micrometer metrics — OPTIONAL tier per the v1.0 catalog; queries here may shift if Micrometer changes shape.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "subscription-service-prometheus" },
      "description": "JVM heap used per service (interface-engine + hapi). The `area` micrometer label distinguishes heap vs nonheap; we slice to heap because that's the only one that triggers OOMs.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showPercentChange": false,
        "textMode": "auto"
      },
      "pluginVersion": "11.4.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "subscription-service-prometheus" },
          "editorMode": "code",
          "expr": "sum by (job) (jvm_memory_used_bytes{area=\"heap\"})",
          "legendFormat": "{{job}}",
          "instant": true,
          "range": false,
          "refId": "A"
        }
      ],
      "title": "JVM heap used",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "subscription-service-prometheus" },
      "description": "HTTP server request rate, sliced by the Spring MVC `uri` template label. High-frequency endpoints rise to the top.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "req/s",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": {
        "legend": { "calcs": ["mean", "lastNotNull"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "11.4.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "subscription-service-prometheus" },
          "editorMode": "code",
          "expr": "topk(10, sum by (uri, job) (rate(http_server_requests_seconds_count[5m])))",
          "legendFormat": "{{job}} {{uri}}",
          "refId": "A"
        }
      ],
      "title": "HTTP server request rate (top 10)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "subscription-service-prometheus" },
      "description": "Total GC pause time per minute, by collector action. Bursts here correlate with latency spikes on the histograms in the other dashboards.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "pause seconds / min",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 3,
      "options": {
        "legend": { "calcs": ["mean", "lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "11.4.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "subscription-service-prometheus" },
          "editorMode": "code",
          "expr": "sum by (job, action) (rate(jvm_gc_pause_seconds_sum[1m]))",
          "legendFormat": "{{job}} {{action}}",
          "refId": "A"
        }
      ],
      "title": "GC pause time",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "subscription-service-prometheus" },
      "description": "HikariCP pool utilization — active connections relative to the max. Saturation here will starve workers regardless of how fast HAPI / matchbox respond.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "connections",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "options": {
        "legend": { "calcs": ["mean", "lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "11.4.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "subscription-service-prometheus" },
          "editorMode": "code",
          "expr": "sum by (job, pool) (hikaricp_connections_active)",
          "legendFormat": "active {{job}} {{pool}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "subscription-service-prometheus" },
          "editorMode": "code",
          "expr": "sum by (job, pool) (hikaricp_connections_max)",
          "legendFormat": "max {{job}} {{pool}}",
          "refId": "B"
        }
      ],
      "title": "HikariCP pool utilization",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "subscription-service-prometheus" },
      "description": "JVM thread count per service. Spikes correlate with worker thrash; a slow climb usually means a thread leak.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "threads",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["mean", "lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "11.4.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "subscription-service-prometheus" },
          "editorMode": "code",
          "expr": "sum by (job) (jvm_threads_live_threads)",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "title": "JVM thread count",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
