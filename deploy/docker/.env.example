# subscription-service Docker Compose environment
#
# Copy to .env (gitignored) and adjust for your deployment. Defaults below are
# development-grade; CHANGE THEM before any non-dev use.
#
# ---------------------------------------------------------------------------
# Postgres (HAPI's datastore)
# ---------------------------------------------------------------------------
POSTGRES_USER=hapi
POSTGRES_PASSWORD=hapi
POSTGRES_DB=hapi

# ---------------------------------------------------------------------------
# Interface-engine's own Postgres database (Epic #378). Lives on the same
# Postgres server as HAPI but a separate database + user. Used by the
# durable inbound-message store, retry tracking, and DLQ.
#
# Provisioned on first boot by deploy/docker/postgres-init/01-create-ipf-db.sh
# (Postgres only runs init scripts when PGDATA is empty — wipe POSTGRES_DATA_DIR
# to re-init if you change these values on an existing deployment).
# ---------------------------------------------------------------------------
IPF_DB_USER=ipf
IPF_DB_PASSWORD=ipf
IPF_DB_NAME=ipf

# ---------------------------------------------------------------------------
# Admin REST API bearer token (Epic #378, ticket #384).
#
# Gates the /admin/* endpoints on the interface engine's HTTP port. When
# empty / unset the endpoints are OPEN (dev convenience) and a WARN is
# logged at startup. In any non-isolated environment, set this to a long
# random string and rotate periodically.
#
# Example:
#   IPF_ADMIN_AUTH_TOKEN=$(openssl rand -hex 32)
#
# Once set, all admin calls must send `Authorization: Bearer <value>`.
# ---------------------------------------------------------------------------
IPF_ADMIN_AUTH_TOKEN=

# ---------------------------------------------------------------------------
# Async worker (Epic #378, ticket #382). Polls `ingested_messages` for
# RECEIVED rows (or retry-ready FAILED rows), drives the matchbox
# transform, POSTs the resulting Bundle to HAPI, and updates the row.
#
# IPF_WORKER_ENABLED — master toggle. Set to false to ingest-only a
#   replica (useful during data migration or when you only want this
#   pod to ACK MLLP traffic without processing the backlog yet).
# IPF_WORKER_POLL_MS — fixed delay between poll cycles. Going below
#   ~200 ms is wasteful (each poll opens a transaction even when the
#   table is empty); above ~10s makes the queue feel laggy under low
#   traffic. 1000 ms is the v1 default.
# IPF_WORKER_BATCH_SIZE — max rows claimed per poll. Bigger batches =
#   higher throughput per cycle but also bigger blast radius if
#   matchbox starts misbehaving (whole batch ends up FAILED). 10 keeps
#   the failure radius small while still letting one pod easily
#   chew through a few hundred messages per second.
# IPF_WORKER_TRANSFORMING_STALE_SECONDS — on JVM startup, any row stuck
#   in TRANSFORMING whose last_attempt_at is older than this threshold
#   is reset to FAILED so the worker retries it. 60s comfortably
#   exceeds the matchbox 30s timeout; setting it shorter risks
#   declaring an in-flight row dead and double-processing it.
# ---------------------------------------------------------------------------
IPF_WORKER_ENABLED=true
IPF_WORKER_POLL_MS=1000
IPF_WORKER_BATCH_SIZE=10
IPF_WORKER_TRANSFORMING_STALE_SECONDS=60

# ---------------------------------------------------------------------------
# Retry policy (Epic #378, ticket #383). When the worker fails on a row
# (matchbox transform raised, HAPI POST raised, etc.) it schedules an
# exponential backoff retry by writing `next_attempt_at`. After
# IPF_MAX_ATTEMPTS failures the row transitions to DEAD_LETTER and stops
# being picked up by the poll loop. The admin retry endpoint (#384) is the
# only way out of DEAD_LETTER.
#
# Default backoff math: 1s, 2s, 4s, 8s, 16s (capped at 5 min). After the
# 5th failure the row hits DLQ. Total wall-clock waited across the four
# retry intervals is ~31s.
#
#   next_attempt_at = now() + min(BASE * FACTOR^(N-1), MAX_MS) ms
#                     where N is the just-incremented attempt count.
#
# IPF_MAX_ATTEMPTS — when (attempt_count+1) >= this value, row → DEAD_LETTER.
# IPF_BACKOFF_BASE_MS — delay applied after the first failure (1s default).
# IPF_BACKOFF_MAX_MS — cap on the computed delay (5 min default).
# IPF_BACKOFF_FACTOR — multiplier between consecutive failures (2.0 = double).
# IPF_DLQ_LOG_LEVEL — severity of the one log line per DLQ transition
#   (ERROR, WARN, INFO, DEBUG, TRACE). WARN by default so it shows up in
#   default operator log scrapes without being noisy.
# ---------------------------------------------------------------------------
IPF_MAX_ATTEMPTS=5
IPF_BACKOFF_BASE_MS=1000
IPF_BACKOFF_MAX_MS=300000
IPF_BACKOFF_FACTOR=2.0
IPF_DLQ_LOG_LEVEL=WARN

# Postgres bind-mount source path (relative to deploy/docker/, or absolute).
#
# Defaults to ./postgres-data so a fresh clone runs without any host-side
# setup. For longer-lived deployments, point this at a directory outside the
# repo (e.g., ${HOME}/subscription-service-data/postgres) so the data
# survives if you rebuild the working tree. Whatever path you choose, the
# directory must exist and be writable by the Postgres container's user
# (uid 999 on the alpine image).
POSTGRES_DATA_DIR=./postgres-data

# ---------------------------------------------------------------------------
# Host ports exposed on the Docker host. Change if these collide with
# something else on your machine.
# ---------------------------------------------------------------------------
HAPI_HOST_PORT=18080
MATCHBOX_HOST_PORT=18081
INTERFACE_ENGINE_HTTP_HOST_PORT=18090
INTERFACE_ENGINE_MLLP_HOST_PORT=2575

# ---------------------------------------------------------------------------
# Image pins. Override here if you need to roll forward/back without editing
# docker-compose.yml.
# ---------------------------------------------------------------------------
POSTGRES_IMAGE=postgres:16-alpine
# HAPI image is now built locally from hapi/Dockerfile (derived from
# hapiproject/hapi:v7.6.0, with the subscription-service auth JAR layered
# in). Override to a registry coordinate when running against a pre-built
# image, e.g. in Kubernetes.
HAPI_IMAGE=subscription-service/hapi:dev
MATCHBOX_IMAGE=europe-west6-docker.pkg.dev/ahdis-ch/ahdis/matchbox:v3.9.13
INTERFACE_ENGINE_IMAGE=subscription-service/interface-engine:dev

# ---------------------------------------------------------------------------
# Feature toggles (see docs/architecture.md). Stubs for now; implemented in
# follow-up tickets.
# ---------------------------------------------------------------------------
# US Core profile validation mode: off | warn | enforce
#   off     — no validation; HAPI accepts inbound resources unchanged (default).
#   warn    — validate; surface findings in the response OperationOutcome but
#             accept the request.
#   enforce — validate; reject ERROR-severity findings with HTTP 422 +
#             OperationOutcome.
# See docs/architecture.md "Profile validation (US Core)".
SUBSCRIPTION_SERVICE_VALIDATION_MODE=off

# Subscription channel security: strict | relaxed | permissive
# Implemented in #368, currently no-op.
SUBSCRIPTION_SERVICE_CHANNEL_SECURITY=strict

# Multi-tenancy: disabled | enabled
# Implemented in #369, currently no-op.
SUBSCRIPTION_SERVICE_MULTITENANCY=disabled

# ---------------------------------------------------------------------------
# JWT authentication (#359, hardened in #370). Set ENABLED=false for local
# dev without a Keycloak realm provisioned; HAPI will then behave like
# upstream and accept anonymous traffic.
#
# When ENABLED=true:
#   - All /fhir/* requests must carry a valid `Authorization: Bearer <jwt>`.
#   - /fhir/metadata and /fhir/.well-known/smart-configuration are anonymous.
#   - SMART scopes in the token's `scope` claim are mapped to HAPI authz
#     rules; tokens without the right scopes get 403 on protected operations.
#
# ISSUER must exactly match the `iss` claim issued by your realm. There is
# NO default — every deployment must supply its own. If AUTH_ENABLED=true
# and ISSUER is empty, HAPI fails fast at startup (ticket #370) with:
#
#   subscription-service.auth.issuer is required when auth is enabled.
#   Set SUBSCRIPTION_SERVICE_AUTH_ISSUER (e.g.,
#   https://your-keycloak.example.com/realms/subscription-service) or set
#   SUBSCRIPTION_SERVICE_AUTH_ENABLED=false for local dev.
#
# Example (modern Keycloak >= 17, Quarkus):
#   https://your-keycloak.example.com/realms/subscription-service
# Example (legacy Keycloak < 17, WildFly with /auth/ prefix):
#   https://your-keycloak.example.com/auth/realms/subscription-service
#
# JWKS_URL defaults to ${ISSUER}/protocol/openid-connect/certs if blank.
# ---------------------------------------------------------------------------
# Default OFF — the quickstart and local dev work without an IdP. Flip to
# `true` once you have an OIDC provider configured below. The deployed
# system MUST run with auth ON in any environment that isn't isolated
# dev/sandbox.
SUBSCRIPTION_SERVICE_AUTH_ENABLED=false
# REQUIRED when SUBSCRIPTION_SERVICE_AUTH_ENABLED=true.
SUBSCRIPTION_SERVICE_AUTH_ISSUER=
SUBSCRIPTION_SERVICE_AUTH_JWKS_URL=
