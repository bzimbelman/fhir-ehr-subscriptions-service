# Default CoreDNS Corefile for the H1 realstack harness.
#
# Forwards everything to the host resolver (1.1.1.1 + 8.8.8.8) so the
# rest of the stack can resolve container hostnames in the default
# bridge network. Tests that need controlled DNS responses (H6 SSRF /
# rebinding scenarios) replace this file with a per-test Corefile and
# reload CoreDNS via SIGUSR1.
. {
    forward . 1.1.1.1 8.8.8.8
    cache 30
    log
    errors
    health :8053
}
