{
  "realm": "subscription-service",
  "displayName": "Subscription Service",
  "displayNameHtml": "<b>Subscription Service</b>",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "waitIncrementSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,
  "failureFactor": 30,
  "accessTokenLifespan": 900,
  "accessTokenLifespanForImplicitFlow": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "ssoSessionIdleTimeoutRememberMe": 0,
  "ssoSessionMaxLifespanRememberMe": 0,
  "offlineSessionIdleTimeout": 2592000,
  "offlineSessionMaxLifespanEnabled": false,
  "offlineSessionMaxLifespan": 5184000,
  "clientSessionIdleTimeout": 0,
  "clientSessionMaxLifespan": 0,
  "clientOfflineSessionIdleTimeout": 0,
  "clientOfflineSessionMaxLifespan": 0,
  "accessCodeLifespan": 60,
  "accessCodeLifespanUserAction": 300,
  "accessCodeLifespanLogin": 1800,
  "actionTokenGeneratedByAdminLifespan": 43200,
  "actionTokenGeneratedByUserLifespan": 300,
  "oauth2DeviceCodeLifespan": 600,
  "oauth2DevicePollingInterval": 5,
  "refreshTokenMaxReuse": 0,
  "revokeRefreshToken": false,
  "defaultSignatureAlgorithm": "RS256",
  "attributes": {
    "frontendUrl": "",
    "acr.loa.map": "{}",
    "clientOfflineSessionIdleTimeout": "0",
    "clientOfflineSessionMaxLifespan": "0",
    "clientSessionIdleTimeout": "0",
    "clientSessionMaxLifespan": "0",
    "userProfileEnabled": "false",
    "oauth2DevicePollingInterval": "5",
    "oauth2DeviceCodeLifespan": "600",
    "shortVerificationUri": ""
  },
  "clientScopes": [
    {
      "name": "system/Subscription.crus",
      "description": "Create, read, update, search FHIR Subscription resources (system context).",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false",
        "consent.screen.text": "Manage FHIR Subscription resources"
      }
    },
    {
      "name": "system/Subscription.r",
      "description": "Read FHIR Subscription resources (system context).",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false",
        "consent.screen.text": "Read FHIR Subscription resources"
      }
    },
    {
      "name": "system/Patient.r",
      "description": "Read FHIR Patient resources (system context).",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false",
        "consent.screen.text": "Read FHIR Patient resources"
      }
    },
    {
      "name": "system/Patient.cruds",
      "description": "Create, read, update, delete, search FHIR Patient resources (system context).",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false",
        "consent.screen.text": "Manage FHIR Patient resources"
      }
    },
    {
      "name": "system/Observation.r",
      "description": "Read FHIR Observation resources (system context).",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false",
        "consent.screen.text": "Read FHIR Observation resources"
      }
    }
  ],
  "defaultDefaultClientScopes": [],
  "defaultOptionalClientScopes": [],
  "clients": [
    {
      "clientId": "subscription-service-cli",
      "name": "Subscription Service CLI (example M2M client)",
      "description": "Example confidential client used to exercise the subscription-service FHIR API via OAuth2 client_credentials. Replace the secret before any non-local use.",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "CHANGE-ME-IN-DEPLOYMENT",
      "redirectUris": [],
      "webOrigins": [],
      "notBefore": 0,
      "bearerOnly": false,
      "consentRequired": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "publicClient": false,
      "frontchannelLogout": false,
      "protocol": "openid-connect",
      "attributes": {
        "access.token.lifespan": "900",
        "client.secret.creation.time": "0",
        "client_credentials.use_refresh_token": "false",
        "oauth2.device.authorization.grant.enabled": "false",
        "oidc.ciba.grant.enabled": "false",
        "tls.client.certificate.bound.access.tokens": "false",
        "use.refresh.tokens": "false"
      },
      "authenticationFlowBindingOverrides": {},
      "fullScopeAllowed": false,
      "nodeReRegistrationTimeout": -1,
      "defaultClientScopes": [
        "system/Subscription.crus",
        "system/Patient.r"
      ],
      "optionalClientScopes": [
        "system/Subscription.r",
        "system/Patient.cruds",
        "system/Observation.r"
      ]
    }
  ],
  "smtpServer": {},
  "eventsEnabled": false,
  "eventsListeners": [
    "jboss-logging"
  ],
  "enabledEventTypes": [],
  "adminEventsEnabled": false,
  "adminEventsDetailsEnabled": false,
  "internationalizationEnabled": false,
  "supportedLocales": [],
  "browserSecurityHeaders": {
    "contentSecurityPolicyReportOnly": "",
    "xContentTypeOptions": "nosniff",
    "referrerPolicy": "no-referrer",
    "xRobotsTag": "none",
    "xFrameOptions": "SAMEORIGIN",
    "contentSecurityPolicy": "frame-src 'self'; frame-ancestors 'self'; object-src 'none';",
    "xXSSProtection": "1; mode=block",
    "strictTransportSecurity": "max-age=31536000; includeSubDomains"
  },
  "passwordPolicy": "length(12) and notUsername(undefined) and notEmail(undefined)"
}
