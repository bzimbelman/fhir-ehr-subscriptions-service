{
  "resourceType": "SubscriptionTopic",
  "url": "http://demo.org/topics/encounter-admit",
  "version": "1.0.0",
  "title": "Encounter admit (demo)",
  "description": "Encounter records as they enter the in-progress state (admission). Demo topic for ADT^A01 walk-throughs.",
  "status": "active",
  "resourceTrigger": [{
    "resource": "Encounter",
    "supportedInteraction": ["create", "update"],
    "queryCriteria": {
      "current": "status=in-progress"
    }
  }],
  "canFilterBy": [{
    "resource": "Encounter",
    "filterParameter": "patient"
  }],
  "notificationShape": [{
    "resource": "Encounter",
    "include": ["Encounter:patient"]
  }]
}
