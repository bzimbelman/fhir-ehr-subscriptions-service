# OIDC provider -- REQUIRED. Use whichever provider the rest of the platform
# uses (Keycloak modern, Keycloak legacy /auth/, Auth0, Okta, Authentik, etc.).
# See docs/auth.md (in the repo root) for per-provider recipes.
#
# Example (Keycloak modern): https://keycloak.example.com/realms/subscription-service
# Example (Auth0):           https://your-tenant.us.auth0.com/
# Example (Okta):            https://your-org.okta.com/oauth2/default
OIDC_ISSUER=
OIDC_CLIENT_ID=subscription-service-ui
OIDC_CLIENT_SECRET=

# Where this UI is served from. NextAuth uses this to construct the redirect
# URI it registers with the OIDC provider. In production this should be the
# externally-visible HTTPS URL (e.g. https://ops.subscription-service.example.com).
NEXTAUTH_URL=http://localhost:3000

# Session encryption key. Generate with `openssl rand -base64 32`.
# REQUIRED in production. NextAuth v5 will refuse to start without it when
# NODE_ENV=production. In dev the framework generates a random value if unset.
AUTH_SECRET=

# Backend admin API base URL. The UI proxies through Next.js API routes
# (so the bearer token stays server-side), so this is the in-cluster URL,
# not anything the browser ever touches.
ADMIN_API_BASE_URL=http://interface-engine:8090

# Bearer token for backend admin endpoints. Must match the value of
# IPF_ADMIN_AUTH_TOKEN on the interface-engine. Treat as a secret.
ADMIN_API_BEARER_TOKEN=

# Optional human-readable cluster/deployment name shown in the dashboard
# top-bar (e.g., "prod-east", "dev-staging"). Falls back to "operator console"
# when unset. Use NEXT_PUBLIC_ prefix to expose to the browser side -- the
# value is not a secret.
NEXT_PUBLIC_DEPLOYMENT_NAME=
