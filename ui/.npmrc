auto-install-peers=true
strict-peer-dependencies=false
side-effects-cache=false

# Don't fail the install if some packages' lifecycle scripts are blocked.
# The packages listed in pnpm-workspace.yaml's `onlyBuiltDependencies` still
# run their scripts; this flag just stops pnpm v11 from exiting non-zero
# (which breaks CI / Docker builds) when other packages have ignored scripts.
strict-dep-builds=false
