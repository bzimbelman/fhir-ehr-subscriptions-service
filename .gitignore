# Build output
build/
target/
out/
dist/
*.jar
*.war
# ...but the gradle wrapper jar is checked in (required for `./gradlew`).
!**/gradle/wrapper/gradle-wrapper.jar

# IDE
.idea/
.vscode/
*.iml
*.ipr
*.iws

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Local environment
.env
.env.local
.env.*.local

# Local persistent data (bind-mounts under deploy/docker/)
deploy/docker/postgres/
deploy/docker/postgres-data/
deploy/docker/data/

# IG package tarballs (fetched by scripts/fetch-igs.sh, never committed)
hapi/igs/*.tgz
matchbox/igs/*.tgz

# Helm
deploy/k8s/charts/*/charts/
deploy/k8s/charts/*/Chart.lock

# Node (for any tooling scripts)
node_modules/

# CDS plugin state (per-worktree, never committed)
.cds/

# Local Docker-build CA injection (corporate MITM workaround). Never committed.
ipf-app/ca-cert/cert.pem
hapi/ca-cert/cert.pem

# Gradle local state and HAPI runtime droppings.
**/.gradle/
ipf-app/id_file

# HAPI HL7v2 random-number-generator state file (written when the library runs locally)
interface-engine/id_file
