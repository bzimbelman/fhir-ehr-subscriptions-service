{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "server",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "http": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "bind": {"type": "string", "minLength": 1},
        "tls": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cert_file": {"type": "string"},
            "key_file": {"type": "string"}
          }
        },
        "probe_bind": {"type": ["string", "null"]}
      },
      "required": ["bind"]
    },
    "websocket": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {"type": "boolean"},
        "max_connections": {"type": "integer", "minimum": 0}
      }
    }
  },
  "required": ["http"]
}
